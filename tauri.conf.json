{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zenith Codex",
  "version": "0.2.0",
  "identifier": "com.zenith.codex",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Zenith Codex",
        "width": 760,
        "height": 120,
        "minWidth": 640,
        "minHeight": 110,
        "resizable": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/zenith-sword.png"
    ]
  }
}
